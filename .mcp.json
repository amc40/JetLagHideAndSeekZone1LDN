{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": ["@playwright/mcp@latest", "--browser", "chromium"],
            "env": {
                "PLAYWRIGHT_BROWSERS_PATH": "/opt/pw-browsers",
                "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
            }
        }
    }
}
