---
import Layout from "@/layouts/Layout.astro";
import { Map } from "@/components/Map";
import { PlacePicker } from "@/components/PlacePicker";
import { SidebarProvider as SidebarProviderL } from "@/components/ui/sidebar-l";
import { SidebarProvider as SidebarProviderR } from "@/components/ui/sidebar-r";
import { QuestionSidebar } from "@/components/QuestionSidebar";
import { ZoneSidebar } from "@/components/ZoneSidebar";
import { MapLayersButton } from "@/components/MapLayersButton";
import { OfflineIndicator } from "@/components/OfflineIndicator";
import { OptionDrawers } from "@/components/OptionDrawers";
import { DesktopSidebarTriggers } from "@/components/DesktopSidebarTriggers";
import { MobileActionBar } from "@/components/MobileActionBar";
import { TutorialDialog } from "@/components/TutorialDialog";
---

<Layout className="bg-jetlag">
    <SidebarProviderL client:load>
        <SidebarProviderR client:load defaultOpen={false}>
            <QuestionSidebar client:only />
            <main class="flex flex-col flex-grow group">
                <div
                    class="flex justify-center"
                    id="map-modal-dialog-container-leaflet"
                >
                    <div class="w-full h-full relative">
                        <DesktopSidebarTriggers client:load />
                        <!-- z-[10000] beats react-toastify's default z-index (9999), so the
                             top-of-screen "loading" toast (Map.tsx refreshQuestions) can't
                             cover Map Layers/Offline/Place Picker and block taps on mobile,
                             where the toast container goes full-width across the top. -->
                        <div
                            class="flex flex-col flex-shrink max-w-fit z-[10000] absolute left-4 right-0 m-auto items-center pointer-events-none group-[.fullscreen]:hidden"
                        >
                            <OfflineIndicator
                                client:load
                                className="mt-4 pointer-events-auto"
                            />
                            <MapLayersButton
                                client:only
                                className="mt-4 overflow-hidden shadow-md pointer-events-auto"
                            />
                            <PlacePicker
                                client:only
                                className="m-4 overflow-hidden pointer-events-auto"
                            />
                        </div>
                        <div
                            class="hidden md:block bottom-[max(1.25rem,env(safe-area-inset-bottom))] right-2 mx-auto mb-2 w-fit absolute z-[1030] group-[.fullscreen]:hidden"
                        >
                            <OptionDrawers client:load />
                        </div>
                        <Map
                            className="w-full group-[.fullscreen]:w-full group-[.fullscreen]:h-full"
                            client:only
                        />
                        <MobileActionBar client:load />
                    </div>
                </div>
            </main>
            <ZoneSidebar client:only />
            <TutorialDialog client:only />
        </SidebarProviderR>
    </SidebarProviderL>
</Layout>
