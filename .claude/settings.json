{
    "permissions": {
        "allow": [
            "Bash(pnpm exec eslint *)",
            "Bash(pnpm exec prettier *)",
            "Bash(pnpm exec tsc *)",
            "Bash(pnpm exec astro *)",
            "Bash(pnpm run lint)",
            "Bash(pnpm run lint:check)",
            "Bash(pnpm run typecheck)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "jq -r '.tool_input.file_path' | { read -r f; pnpm exec prettier --write \"$f\"; } 2>/dev/null || true",
                        "statusMessage": "Formatting with Prettier..."
                    }
                ]
            }
        ]
    }
}
